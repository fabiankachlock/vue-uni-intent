{
  "name": "vue-uni-intent",
  "version": "1.0.1",
  "description": "Game-menu-style focus control for Vue 3, navigable by keyboard, mouse, and gamepad featuring spatial navigation using from DOM positions.",
  "keywords": [
    "vue",
    "vue3",
    "spatial-navigation",
    "focus-management",
    "keyboard-navigation",
    "gamepad",
    "accessibility",
    "roving-tabindex",
    "game-menu",
    "composables"
  ],
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fabiankachlock/vue-uni-intent.git"
  },
  "author": {
    "name": "Fabian Kachlock",
    "email": "contact@fabiankachlock.dev",
    "url": "https://fabiankachlock.dev"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s \"lint:*\"",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/",
    "release": "./scripts/release.sh",
    "prepare": "husky"
  },
  "peerDependencies": {
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.72.0",
    "eslint-plugin-vue": "~10.9.2",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.58.0",
    "oxlint": "~1.73.0",
    "remark-gfm": "^4.0.1",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.10",
    "vue": "^3.5.38",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
